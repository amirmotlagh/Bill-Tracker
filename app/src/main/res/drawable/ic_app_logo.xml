<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Premium Gradient Background Rounded Card (Squircle) -->
    <path
        android:pathData="M 20,10 C 10,10 10,20 10,30 L 10,70 C 10,80 10,90 20,90 L 80,90 C 90,90 90,80 90,70 L 90,30 C 90,20 90,10 80,10 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="10"
                android:startY="10"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0.0" android:color="#2563EB" /> <!-- Sapphire Accent -->
                <item android:offset="1.0" android:color="#001D35" /> <!-- Navy Primary -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Stylized Document / Bill Layer (White, semi-transparent) -->
    <path
        android:fillColor="#33FFFFFF"
        android:pathData="M 30,28 L 70,28 L 70,72 L 30,72 Z" />

    <!-- Bill Details Lines (White) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 35,35 L 55,35 L 55,39 L 35,39 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 35,45 L 65,45 L 65,49 L 35,49 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 35,55 L 50,55 L 50,59 L 35,59 Z" />

    <!-- Success Accent: Growing Arrow or Checkmark (Soft Emerald) -->
    <path
        android:fillColor="#10B981"
        android:pathData="M 58,54 L 62,50 L 68,56 L 78,44 L 82,48 L 68,64 Z" />

    <!-- Sparkle/Success dots (Gold/Yellow Accent) -->
    <path
        android:fillColor="#FBBF24"
        android:pathData="M 76,26 A 3,3 0 1,1 70,26 A 3,3 0 1,1 76,26" />
</vector>
